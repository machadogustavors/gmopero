generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum ServiceOrderStatus {
  DRAFT
  OPEN
  CLOSED
  INVOICED
  CANCELLED
}

enum ItemType {
  PART
  SERVICE
}

enum InvoiceStatus {
  PROCESSING
  COMPLETED
  REJECTED
  CANCELLED
  DENIED
}

enum InvoiceType {
  NFE
  NFCE
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_SLIP
  BANK_TRANSFER
}

enum PurchaseInvoiceStatus {
  DRAFT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum StockMovementType {
  PURCHASE_IN
  SERVICE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  REVERSAL
}

// ──────────────────────────────────────────
// Company (tenant)
// ──────────────────────────────────────────

model Company {
  id                String   @id @default(uuid())
  name              String
  taxId             String?  @unique @map("tax_id") // CNPJ
  legalName         String?  @map("legal_name")
  stateRegistration String?  @map("state_registration")
  street            String?
  number            String?
  complement        String?
  neighborhood      String?
  cityCode          String?  @map("city_code")
  city              String?
  state             String?
  zipCode              String?  @map("zip_code")
  phone                String?
  email                String?
  fiscalRegime         Int?     @map("fiscal_regime") // 1=Simples Nacional, 2=SN Excesso, 3=Regime Normal
  defaultIcmsCst       String?  @map("default_icms_cst")    // CST ICMS (regime normal): 00, 10, 20, etc.
  defaultIcmsCsosn     String?  @map("default_icms_csosn")  // CSOSN (simples nacional): 102, 101, 500, etc.
  defaultPisCst        String?  @map("default_pis_cst")     // CST PIS: 01, 04, 06, 07, 08, 49, 99, etc.
  defaultCofinsCst     String?  @map("default_cofins_cst")  // CST COFINS: 01, 04, 06, 07, 08, 49, 99, etc.
  defaultIcmsOrigem    String?  @map("default_icms_origem") // Origem da mercadoria: 0=Nacional, 1=Estrangeira importação direta, etc.
  plugnotasRegistered  Boolean  @default(false) @map("plugnotas_registered")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  users         User[]
  customers     Customer[]
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  invoices      Invoice[]
  payments      Payment[]
  products      Product[]
  suppliers     Supplier[]
  purchaseInvoices PurchaseInvoice[]
  stockMovements StockMovement[]

  @@map("companies")
}

// ──────────────────────────────────────────
// User
// ──────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String?
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("users")
}

// ──────────────────────────────────────────
// Customer
// ──────────────────────────────────────────

model Customer {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  taxId        String?  @map("tax_id") // CPF or CNPJ
  name         String
  email        String?
  phone        String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  cityCode     String?  @map("city_code")
  city         String?
  state        String?
  zipCode      String?  @map("zip_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id])
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]

  @@index([companyId])
  @@index([taxId])
  @@map("customers")
}

// ──────────────────────────────────────────
// Vehicle
// ──────────────────────────────────────────

model Vehicle {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  customerId   String   @map("customer_id")
  licensePlate String   @map("license_plate")
  brand        String?
  model        String?
  year         Int?
  color        String?
  mileage      Int?     @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])
  serviceOrders ServiceOrder[]

  @@unique([companyId, licensePlate])
  @@index([companyId])
  @@index([customerId])
  @@map("vehicles")
}

// ──────────────────────────────────────────
// Product / Service Catalog
// ──────────────────────────────────────────

model Product {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  type          ItemType
  code          String?
  description   String
  ncm           String?
  cfop          String?
  unitPrice     Decimal  @map("unit_price") @db.Decimal(12, 2)
  unitCost      Decimal  @default(0) @map("unit_cost") @db.Decimal(12, 2)
  currentStock  Decimal  @default(0) @map("current_stock") @db.Decimal(12, 3)
  reorderLevel  Decimal  @default(0) @map("reorder_level") @db.Decimal(12, 3)
  lastReceivedAt DateTime? @map("last_received_at")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company              Company               @relation(fields: [companyId], references: [id])
  serviceOrderItems    ServiceOrderItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  stockMovements       StockMovement[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, currentStock])
  @@map("products")
}

// ──────────────────────────────────────────
// Suppliers / Purchase Invoices
// ──────────────────────────────────────────

model Supplier {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String
  taxId        String?  @map("tax_id")
  email        String?
  phone        String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  cityCode     String?  @map("city_code")
  city         String?
  state        String?
  zipCode      String?  @map("zip_code")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company          Company           @relation(fields: [companyId], references: [id])
  purchaseInvoices PurchaseInvoice[]

  @@index([companyId])
  @@index([companyId, taxId])
  @@map("suppliers")
}

model PurchaseInvoice {
  id            String                @id @default(uuid())
  companyId     String                @map("company_id")
  supplierId    String                @map("supplier_id")
  invoiceNumber String?               @map("invoice_number")
  series        String?
  accessKey     String?               @map("access_key")
  issuedAt      DateTime?             @map("issued_at")
  status        PurchaseInvoiceStatus @default(DRAFT)
  notes         String?
  totalAmount   Decimal               @default(0) @map("total_amount") @db.Decimal(12, 2)
  receivedAt    DateTime?             @map("received_at")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  company  Company               @relation(fields: [companyId], references: [id])
  supplier Supplier              @relation(fields: [supplierId], references: [id])
  items    PurchaseInvoiceItem[]

  @@index([companyId])
  @@index([supplierId])
  @@index([companyId, issuedAt])
  @@index([status])
  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  purchaseInvoiceId String   @map("purchase_invoice_id")
  productId         String   @map("product_id")
  description       String
  ncm               String?
  cfop              String?
  quantity          Decimal  @default(1) @db.Decimal(10, 3)
  unitCost          Decimal  @map("unit_cost") @db.Decimal(12, 2)
  totalCost         Decimal  @map("total_cost") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([purchaseInvoiceId])
  @@index([productId])
  @@map("purchase_invoice_items")
}

model StockMovement {
  id             String            @id @default(uuid())
  companyId      String            @map("company_id")
  productId      String            @map("product_id")
  type           StockMovementType
  quantity       Decimal           @db.Decimal(12, 3)
  unitCost       Decimal?          @map("unit_cost") @db.Decimal(12, 2)
  notes          String?
  referenceType  String?           @map("reference_type")
  referenceId    String?           @map("reference_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([productId])
  @@index([productId, createdAt])
  @@map("stock_movements")
}

// ──────────────────────────────────────────
// Service Order
// ──────────────────────────────────────────

model ServiceOrder {
  id            String             @id @default(uuid())
  companyId     String             @map("company_id")
  customerId    String             @map("customer_id")
  vehicleId     String?            @map("vehicle_id")
  orderNumber   Int                @map("order_number")
  status        ServiceOrderStatus @default(DRAFT)
  description   String?
  totalParts    Decimal            @default(0) @map("total_parts") @db.Decimal(12, 2)
  totalServices Decimal            @default(0) @map("total_services") @db.Decimal(12, 2)
  totalAmount   Decimal            @default(0) @map("total_amount") @db.Decimal(12, 2)
  closedAt      DateTime?          @map("closed_at")
  invoicedAt    DateTime?          @map("invoiced_at")
  cancelledAt   DateTime?          @map("cancelled_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id])

  items    ServiceOrderItem[]
  invoices Invoice[]
  payments Payment[]

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@map("service_orders")
}

// ──────────────────────────────────────────
// Service Order Item
// ──────────────────────────────────────────

model ServiceOrderItem {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  serviceOrderId String   @map("service_order_id")
  productId      String?  @map("product_id")
  type           ItemType
  description    String
  ncm            String?
  cfop           String?
  quantity       Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice     Decimal  @map("total_price") @db.Decimal(12, 2)
  stockMovedAt   DateTime? @map("stock_moved_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([companyId])
  @@index([serviceOrderId])
  @@index([productId])
  @@map("service_order_items")
}

// ──────────────────────────────────────────
// Invoice (Nota Fiscal)
// ──────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  companyId      String        @map("company_id")
  serviceOrderId String        @map("service_order_id")
  plugnotasId    String?       @map("plugnotas_id")
  integrationId  String?       @unique @map("integration_id")
  type           InvoiceType   @default(NFE)
  status         InvoiceStatus @default(PROCESSING)
  accessKey      String?       @map("access_key")
  invoiceNumber  String?       @map("invoice_number")
  series         String?
  pdfUrl         String?       @map("pdf_url")
  xmlUrl         String?       @map("xml_url")
  message        String?
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  issuedAt       DateTime?     @map("issued_at")
  cancelledAt    DateTime?     @map("cancelled_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  company      Company      @relation(fields: [companyId], references: [id])
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([companyId])
  @@index([serviceOrderId])
  @@index([status])
  @@map("invoices")
}

// ──────────────────────────────────────────
// Payment
// ──────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid())
  companyId      String        @map("company_id")
  serviceOrderId String        @map("service_order_id")
  method         PaymentMethod
  amount         Decimal       @db.Decimal(12, 2)
  paidAt         DateTime      @default(now()) @map("paid_at")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  company      Company      @relation(fields: [companyId], references: [id])
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  @@index([companyId])
  @@index([serviceOrderId])
  @@map("payments")
}
